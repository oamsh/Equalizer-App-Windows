                                            <TextBlock Grid.Column="2" Text="100 Hz" Foreground="{DynamicResource MutedTextBrush}" FontSize="9" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="200 Hz" Foreground="{DynamicResource MutedTextBrush}" FontSize="9" HorizontalAlignment="Center"/>
