                    <Border x:Name="SettingsContentPanel" Grid.Column="1" Style="{StaticResource GlassPanel}" Margin="0,0,10,10" Padding="25" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="20" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="0,0,10,0">

                                    <Border Style="{StaticResource GlassOverlay}" Padding="20" Margin="0,0,0,15">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="👁️" Foreground="{DynamicResource AccentBrush}" FontSize="16" Margin="0,0,10,0"/>
                                                <TextBlock Text="Visualizer &amp; Graphics" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="16"/>
                                            </StackPanel>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Visualizer Frame Rate" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Lower the frame rate to save CPU/GPU resources on laptops." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <ComboBox x:Name="VisualizerFpsSelector" Grid.Column="1" Width="150" Height="30" SelectedIndex="1" Style="{StaticResource DarkComboBox}" VerticalAlignment="Center" SelectionChanged="VisualizerFpsSelector_SelectionChanged">
                                                    <ComboBoxItem Content="30 FPS (Eco)"/>
                                                    <ComboBoxItem Content="60 FPS (Default)"/>
                                                    <ComboBoxItem Content="120 FPS (Ultra)"/>
                                                </ComboBox>
                                            </Grid>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Spectrum Falloff Speed" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Controls how fast the spectrum bars drop after a bass hit." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <Slider x:Name="SpectrumFalloffSlider" Grid.Column="1" Width="150" Value="40" Maximum="100" Style="{StaticResource VolumeSlider}" VerticalAlignment="Center" ValueChanged="SpectrumFalloffSlider_ValueChanged"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Disable Visualizers (Eco Mode)" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Completely pauses all background visualizer rendering." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <ToggleButton x:Name="EcoModeToggle" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="False" VerticalAlignment="Center" Click="EcoModeToggle_Click"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Enable Advanced OS Blur" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Uses Windows Acrylic Blur. Disable to improve performance or fix visual glitches." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <ToggleButton x:Name="OSBlurToggle" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" VerticalAlignment="Center" Click="OSBlurToggle_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource GlassOverlay}" Padding="20" Margin="0,0,0,10">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="⚙️" Foreground="{DynamicResource AccentBrush}" FontSize="16" Margin="0,0,10,0"/>
                                                <TextBlock Text="Application" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="16"/>
                                            </StackPanel>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Start with Windows" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Automatically load your Equalizer profile when the PC turns on." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <ToggleButton x:Name="StartWithWindowsToggle" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" VerticalAlignment="Center" Click="StartWithWindowsToggle_Click"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Minimize to System Tray" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Hide the app to the taskbar instead of closing it entirely." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <ToggleButton x:Name="MinimizeToTrayToggle" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" VerticalAlignment="Center"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Always on Top" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Keep the application floating above other windows." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <ToggleButton x:Name="AlwaysOnTopToggle" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="False" VerticalAlignment="Center" Click="AlwaysOnTopToggle_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border x:Name="PlaybackContentPanel" Grid.Column="1" Style="{StaticResource GlassPanel}" Margin="0,0,10,10" Padding="40" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <TextBlock x:Name="PlaybackAppSourceText" Text="Playing from System" Foreground="{DynamicResource AccentBrushLight}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                <TextBlock Text="Now Playing" FontWeight="SemiBold" FontSize="20" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <Grid Grid.Row="1" Width="250" Height="250" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10">

                                <Ellipse Width="200" Height="200" Fill="{DynamicResource AccentBrush}" Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="30" ShadowDepth="0"/>
                                    </Ellipse.Effect>
                                </Ellipse>

                                <Ellipse Width="200" Height="200" Fill="#111520" Stroke="{DynamicResource BorderBrush}" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Grid Width="200" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="DiskRotation" Angle="0" CenterX="100" CenterY="100"/>
                                    </Grid.RenderTransform>

                                    <Ellipse Margin="8" Stroke="#1AFFFFFF" StrokeThickness="1" StrokeDashArray="4 4"/>
                                    <Ellipse Margin="18" Stroke="#1AFFFFFF" StrokeThickness="1" StrokeDashArray="2 6"/>
                                    <Ellipse Margin="28" Stroke="#1AFFFFFF" StrokeThickness="1" StrokeDashArray="6 2"/>
                                    <Ellipse Margin="40" Stroke="#1AFFFFFF" StrokeThickness="1" StrokeDashArray="3 5"/>

                                    <Ellipse Margin="55">
                                        <Ellipse.Fill>
                                            <ImageBrush x:Name="PlaybackBigImageBrush" Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </Grid>

                                <Ellipse Width="14" Height="14" Fill="#0B0E14" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Ellipse Width="7" Height="7" Fill="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>

                            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,30" MaxWidth="450">
                                <ScrollViewer x:Name="PlaybackBigTitleScroller" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,5">
                                    <TextBlock x:Name="PlaybackBigTitle" Text="{Binding Text, ElementName=TrackTitle}" FontSize="28" FontWeight="Bold" Foreground="White" TextWrapping="NoWrap" HorizontalAlignment="Center"/>
                                </ScrollViewer>
                                <ScrollViewer x:Name="PlaybackBigArtistScroller" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                                    <TextBlock x:Name="PlaybackBigArtist" Text="{Binding Text, ElementName=TrackArtist}" FontSize="16" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="NoWrap" HorizontalAlignment="Center"/>
                                </ScrollViewer>
                            </StackPanel>

                            <Grid Grid.Row="3" Margin="40,0,40,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="PlaybackBigCurrentTimeText" Text="{Binding Text, ElementName=CurrentTimeText}" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,0"/>

                                <Slider x:Name="PlaybackBigSeekSlider" Grid.Column="1" Style="{StaticResource VolumeSlider}" VerticalAlignment="Center" Margin="8,0"
                                        Minimum="{Binding Minimum, ElementName=SeekSlider}" Maximum="{Binding Maximum, ElementName=SeekSlider}" Value="{Binding Value, ElementName=SeekSlider}"
                                        Thumb.DragStarted="SeekSlider_DragStarted" 
                                        Thumb.DragCompleted="SeekSlider_DragCompleted" 
                                        ValueChanged="SeekSlider_ValueChanged"
                                        PreviewMouseLeftButtonUp="SeekSlider_PreviewMouseLeftButtonUp"/>

                                <TextBlock x:Name="PlaybackBigTotalTimeText" Text="{Binding Text, ElementName=TotalTimeText}" Grid.Column="2" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="15,0,0,0"/>
                            </Grid>

                            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0">

                                <Button x:Name="PlaybackBigPrevBtn" Style="{StaticResource DarkButton}" BorderThickness="0" Width="50" Height="50" Margin="0,0,20,0" Click="Previous_Click">
                                    <Path Fill="{DynamicResource TextBrush}" Stretch="Uniform" Width="16" Height="16" Data="M10,2 L10,14 L3,8 Z M2,2 L3,2 L3,14 L2,14 Z"/>
                                </Button>

                                <Border x:Name="PlaybackBigPlayPauseBorder" MouseLeftButtonDown="PlayPause_Click" Cursor="Hand" Width="70" Height="70" Background="{DynamicResource AccentBrush}" CornerRadius="35" Margin="0,0,20,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="25" ShadowDepth="0"/>
                                    </Border.Effect>
                                    <Path x:Name="PlaybackBigPlayPauseIcon" Fill="White" Stretch="Uniform" Width="24" Height="24" Margin="5,0,0,0" Data="{Binding Data, ElementName=PlayPauseIcon}"/>
                                </Border>

                                <Button x:Name="PlaybackBigNextBtn" Style="{StaticResource DarkButton}" BorderThickness="0" Width="50" Height="50" Margin="0,0,20,0" Click="Next_Click">
                                    <Path Fill="{DynamicResource TextBrush}" Stretch="Uniform" Width="16" Height="16" Data="M2,2 L2,14 L9,8 Z M10,2 L11,2 L11,14 L10,14 Z"/>
                                </Button>

                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- NEW: Analog & Pro Features Content Panel -->
                    <Border x:Name="AnalogContentPanel" Grid.Column="1" Style="{StaticResource GlassPanel}" Margin="0,0,10,10" Padding="25" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Analog &amp; Pro Features" FontWeight="SemiBold" FontSize="20" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="0,0,10,0">

                                    <Border Style="{StaticResource GlassOverlay}" Padding="20" Margin="0,0,0,15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Analog Fatness" Foreground="{DynamicResource TextBrush}" FontSize="16" FontWeight="SemiBold"/>
                                                <TextBlock Text="Simulates analog saturation and warmth. Great for giving a fuller sound to thin-sounding tracks." Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="FatModeToggle" Grid.Column="1" Style="{StaticResource ProFeatureToggleStyle}" IsChecked="False" Click="FatModeToggle_Click" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource GlassOverlay}" Padding="20" Margin="0,0,0,15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Super Bass" Foreground="{DynamicResource TextBrush}" FontSize="16" FontWeight="SemiBold"/>
                                                <TextBlock Text="Enhances low frequencies to deliver deep, punchy bass without causing distortion. Perfect for electronic and dance music." Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="SuperBassToggle" Grid.Column="1" Style="{StaticResource ProFeatureToggleStyle}" IsChecked="False" Click="SuperBassToggle_Click" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource GlassOverlay}" Padding="20" Margin="0,0,0,15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="3D Spatial" Foreground="{DynamicResource TextBrush}" FontSize="16" FontWeight="SemiBold"/>
                                                <TextBlock Text="Applies virtual surround processing and stereo widening to create an immersive audio experience." Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="SpatialSoundToggle" Grid.Column="1" Style="{StaticResource ProFeatureToggleStyle}" IsChecked="False" Click="SpatialSoundToggle_Click" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                </Grid>

                <Border x:Name="BottomPlaybackBarBorder" Grid.Row="2" Style="{StaticResource GlassPanel}" Margin="10,0,10,10" Padding="20,10" Visibility="Visible">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="35"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="35"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CurrentTimeText" Text="0:00" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>

                            <Slider x:Name="SeekSlider" Grid.Column="1" Style="{StaticResource VolumeSlider}" VerticalAlignment="Center"
                                    Thumb.DragStarted="SeekSlider_DragStarted" 
                                    Thumb.DragCompleted="SeekSlider_DragCompleted" 
                                    ValueChanged="SeekSlider_ValueChanged"
                                    PreviewMouseLeftButtonUp="SeekSlider_PreviewMouseLeftButtonUp"/>

                            <TextBlock x:Name="TotalTimeText" Text="0:00" Grid.Column="2" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Border Width="48" Height="48" Style="{StaticResource GlassOverlay}" MinWidth="48">
                                    <Grid>
                                        <Path x:Name="TrackIcon" Fill="{DynamicResource AccentBrush}" Stretch="Uniform" Width="22" Height="22" Data="M9,3 L19,1 L19,12 A3.5,3.5 0 1,1 15.5,15.5 L15.5,7 L9,8 L9,14 A3.5,3.5 0 1,1 5.5,17.5 L5.5,3 Z"/>
                                        <Border CornerRadius="5">
                                            <Border.Background>
                                                <ImageBrush x:Name="TrackImageBrush" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                    </Grid>
                                </Border>
                                <StackPanel VerticalAlignment="Center" Margin="15,0,0,0" MaxWidth="220">
                                    <ScrollViewer x:Name="TrackTitleScroller" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                                        <TextBlock x:Name="TrackTitle" Text="Unknown Track" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="14" TextWrapping="NoWrap"/>
                                    </ScrollViewer>
                                    <ScrollViewer x:Name="TrackArtistScroller" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Margin="0,4,0,0">
                                        <TextBlock x:Name="TrackArtist" Text="Unknown Artist" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" TextWrapping="NoWrap"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Click="Previous_Click" Style="{StaticResource DarkButton}" BorderThickness="0" Margin="0,0,15,0" Width="35" Height="35">
                                    <Path Fill="{DynamicResource MutedTextBrush}" Stretch="Uniform" Width="12" Height="12" Data="M10,2 L10,14 L3,8 Z M2,2 L3,2 L3,14 L2,14 Z"/>
                                </Button>

                                <Border x:Name="PlayPauseBorder" MouseLeftButtonDown="PlayPause_Click" Cursor="Hand" Width="44" Height="44" Background="{DynamicResource AccentBrush}" CornerRadius="22" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="15" ShadowDepth="0"/>
                                    </Border.Effect>
                                    <Path x:Name="PlayPauseIcon" Fill="White" Stretch="Uniform" Width="14" Height="14" Margin="3,0,0,0" Data="M2,2 L14,8 L2,14 Z"/>
                                </Border>

                                <Button Click="Next_Click" Style="{StaticResource DarkButton}" BorderThickness="0" Margin="15,0,0,0" Width="35" Height="35">
                                    <Path Fill="{DynamicResource MutedTextBrush}" Stretch="Uniform" Width="12" Height="12" Data="M2,2 L2,14 L9,8 Z M10,2 L11,2 L11,14 L10,14 Z"/>
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Path Fill="{DynamicResource MutedTextBrush}" Stretch="Uniform" Width="14" Height="14" Margin="0,0,12,0" Data="M2,5 L5,5 L9,2 L9,14 L5,11 L2,11 Z M11,4 A5,5 0 0,1 11,12 M13,2 A8,8 0 0,1 13,14"/>
                                <Slider x:Name="VolumeSliderControl" Style="{StaticResource VolumeSlider}" Width="110" Maximum="100" Value="80" VerticalAlignment="Center" ValueChanged="VolumeSliderControl_ValueChanged"/>
                                <TextBlock Text="{Binding Value, ElementName=VolumeSliderControl, StringFormat={}{0:0}%}" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="15,0,0,0" Width="30" TextAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="CompactPlaybackPanel" Grid.Row="1" Grid.RowSpan="2" Style="{StaticResource GlassPanel}" Margin="15,5,15,20" Padding="25,20,25,25" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="130" Height="130" CornerRadius="8" Background="{DynamicResource WindowBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,25,0" VerticalAlignment="Center">
                            <Grid>
                                <Path x:Name="CompactTrackIcon" Fill="{DynamicResource AccentBrush}" Stretch="Uniform" Width="36" Height="36" Data="M9,3 L19,1 L19,12 A3.5,3.5 0 1,1 15.5,15.5 L15.5,7 L9,8 L9,14 A3.5,3.5 0 1,1 5.5,17.5 L5.5,3 Z" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border CornerRadius="7">
                                    <Border.Background>
                                        <ImageBrush x:Name="CompactTrackImageBrush" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                                <TextBlock Text="{Binding Text, ElementName=TrackTitle}" Foreground="{DynamicResource TextBrush}" FontWeight="Bold" FontSize="19" LineHeight="24" Padding="0,2" TextTrimming="CharacterEllipsis" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding Text, ElementName=TrackArtist}" Foreground="{DynamicResource MutedTextBrush}" FontSize="13" TextTrimming="CharacterEllipsis" HorizontalAlignment="Left" Margin="0,2,0,0"/>
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Text, ElementName=CurrentTimeText}" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <Slider x:Name="CompactSeekSlider" Grid.Column="1" Style="{StaticResource VolumeSlider}" VerticalAlignment="Center" Margin="10,0"
                                        Minimum="{Binding Minimum, ElementName=SeekSlider}" Maximum="{Binding Maximum, ElementName=SeekSlider}" Value="{Binding Value, ElementName=SeekSlider}"
                                        Thumb.DragStarted="SeekSlider_DragStarted"
                                        Thumb.DragCompleted="SeekSlider_DragCompleted"
                                        ValueChanged="SeekSlider_ValueChanged"
                                        PreviewMouseLeftButtonUp="SeekSlider_PreviewMouseLeftButtonUp"/>
                                <TextBlock Text="{Binding Text, ElementName=TotalTimeText}" Grid.Column="2" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="5">
                                    <Button Style="{StaticResource DarkButton}" BorderThickness="0" Width="38" Height="38" Margin="0,0,15,0" Click="Previous_Click">
                                        <Path Fill="{DynamicResource MutedTextBrush}" Stretch="Uniform" Width="13" Height="13" Data="M10,2 L10,14 L3,8 Z M2,2 L3,2 L3,14 L2,14 Z"/>
                                    </Button>

                                    <Border x:Name="CompactPlayPauseBorder" MouseLeftButtonDown="PlayPause_Click" Cursor="Hand" Width="48" Height="48" Background="{DynamicResource AccentBrush}" CornerRadius="24" Margin="0,0,15,0" RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Border.Effect>
                                            <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="15" ShadowDepth="0"/>
                                        </Border.Effect>
                                        <Path x:Name="CompactPlayPauseIcon" Fill="White" Stretch="Uniform" Width="16" Height="16" Margin="3,0,0,0" Data="M2,2 L14,8 L2,14 Z"/>
                                    </Border>

                                    <Button Style="{StaticResource DarkButton}" BorderThickness="0" Width="38" Height="38" Click="Next_Click">
                                        <Path Fill="{DynamicResource MutedTextBrush}" Stretch="Uniform" Width="13" Height="13" Data="M2,2 L2,14 L9,8 Z M10,2 L11,2 L11,14 L10,14 Z"/>
                                    </Button>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,5,0">
                                    <Path Fill="{DynamicResource MutedTextBrush}" Stretch="Uniform" Width="14" Height="14" Margin="0,0,10,0" Data="M2,5 L5,5 L9,2 L9,14 L5,11 L2,11 Z M11,4 A5,5 0 0,1 11,12 M13,2 A8,8 0 0,1 13,14"/>
                                    <Slider x:Name="CompactVolumeSlider" Style="{StaticResource VolumeSlider}" Width="90" Maximum="100" VerticalAlignment="Center" ValueChanged="VolumeSliderControl_ValueChanged"/>
                                    <TextBlock Text="{Binding Value, ElementName=CompactVolumeSlider, StringFormat={}{0:0}%}" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0" Width="30" TextAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- Redesigned About Overlay -->
        <Grid x:Name="AboutOverlay" Visibility="Collapsed" Opacity="0" Panel.ZIndex="100">
            <!-- Backdrop -->
            <Border Background="#CC07090E" MouseLeftButtonDown="CloseAbout_Click"/>

            <!-- Main Card -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="460" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="AboutScale" ScaleX="0.9" ScaleY="0.9"/>
                </Border.RenderTransform>

                <Grid>
                    <!-- Glowing Drop Shadow for the card -->
                    <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="20" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="50" ShadowDepth="20" Opacity="0.6" Direction="270"/>
                        </Border.Effect>
                    </Border>

                    <!-- Inner Content -->
                    <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="20" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="140"/>
                                <!-- Header/Banner Area -->
                                <RowDefinition Height="*"/>
                                <!-- Content Area -->
                            </Grid.RowDefinitions>

                            <!-- Banner Background -->
                            <Border Grid.Row="0" Background="{DynamicResource SpectrumGradientBrush}" Opacity="0.15"/>
                            <Path Grid.Row="0" Fill="{DynamicResource AccentBrush}" Opacity="0.1" Stretch="Fill" Data="M0,140 L460,80 L460,0 L0,0 Z"/>

                            <!-- Close Button (Fixed) -->
                            <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Width="32" Height="32" Margin="0,15,15,0" Style="{StaticResource CircleButtonStyle}" Background="{DynamicResource GlassOverlayBrush}" BorderThickness="0" Click="CloseAbout_Click">
                                <Path Stroke="{DynamicResource MutedTextBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Stretch="Uniform" Width="10" Height="10" Data="M0,0 L10,10 M10,0 L0,10"/>
                            </Button>

                            <!-- Content Container -->
                            <Grid Grid.Row="1" Margin="30, -50, 30, 30">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <!-- Avatar -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Name -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Role Badge -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Bio -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Separator -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Socials -->
                                </Grid.RowDefinitions>

                                <!-- Profile Avatar -->
                                <Grid Grid.Row="0" Width="110" Height="110" HorizontalAlignment="Center" Margin="0,0,0,15">
                                    <!-- Animated Rings -->
                                    <Ellipse Stroke="{DynamicResource AccentBrushLight}" StrokeThickness="2" StrokeDashArray="2 4" Opacity="0.5" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform x:Name="AboutRing1" Angle="0"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <Ellipse Stroke="{DynamicResource AccentBrush}" StrokeThickness="2" StrokeDashArray="4 2" Margin="5" Opacity="0.7" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform x:Name="AboutRing2" Angle="0"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>

                                    <!-- Actual Image -->
                                    <Border Margin="10" CornerRadius="45" Background="{DynamicResource WindowBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2">
                                        <Border.Effect>
                                            <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                                        </Border.Effect>
                                        <Ellipse>
                                            <Ellipse.Fill>
                                                <ImageBrush x:Name="ProfileImageBrush" Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </Border>
                                </Grid>

                                <!-- Name -->
                                <TextBlock Grid.Row="1" Text="Om" Foreground="{DynamicResource TextBrush}" FontWeight="Bold" FontSize="26" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                                <!-- Role Badge -->
                                <Border Grid.Row="2" Background="{DynamicResource GlassOverlayBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="12" HorizontalAlignment="Center" Padding="12,4" Margin="0,0,0,20">
                                    <TextBlock Text="Software Developer" Foreground="{DynamicResource AccentBrushLight}" FontWeight="SemiBold" FontSize="12"/>
                                </Border>

                                <!-- Bio -->
                                <TextBlock Grid.Row="3" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" FontSize="13" LineHeight="22" Margin="0,0,0,25">
                                    Passionate software developer specializing in C# and Unity game development. Dedicated to crafting immersive 3D experiences and efficient mechanics. Always exploring new technologies, from game engines to Android system modding, to build better solutions.
                                </TextBlock>

                                <Border Grid.Row="4" Height="1" Background="{DynamicResource BorderBrush}" Margin="20,0,20,20"/>

                                <!-- Social Buttons -->
                                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource DarkButton}" Background="{DynamicResource GlassOverlayBrush}" BorderThickness="1" Padding="15,8" Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Fill="{DynamicResource MutedTextBrush}" Stretch="Uniform" Width="14" Height="14" Data="M12,0 C5.37,0 0,5.37 0,12 C0,17.31 3.44,21.81 8.2,23.38 C8.8,23.49 9.02,23.12 9.02,22.81 C9.02,22.53 9.01,21.73 9.01,20.67 C5.67,21.4 4.97,19.06 4.97,19.06 C4.42,17.67 3.63,17.29 3.63,17.29 C2.54,16.54 3.71,16.56 3.71,16.56 C4.92,16.64 5.56,17.8 5.56,17.8 C6.63,19.64 8.36,19.11 8.97,18.8 C9.08,18.11 9.34,17.58 9.63,17.28 C6.97,16.98 4.16,15.95 4.16,11.37 C4.16,10.06 4.63,8.99 5.39,8.14 C5.27,7.84 4.86,6.62 5.51,5.03 C5.51,5.03 6.51,4.71 8.99,6.39 C9.94,6.13 10.97,6.01 11.99,6.01 C13.01,6.01 14.04,6.13 14.99,6.39 C17.47,4.71 18.47,5.03 18.47,5.03 C19.12,6.62 18.71,7.84 18.59,8.14 C19.35,8.99 19.82,10.06 19.82,11.37 C19.82,15.96 17.01,16.98 14.34,17.28 C14.71,17.59 15.03,18.2 15.03,19.01 C15.03,20.17 15.02,21.11 15.02,21.41 C15.02,21.72 15.24,22.1 15.85,21.99 C20.55,20.42 24,15.95 24,10.51 C24,4.71 18.63,0 12,0 Z"/>
                                            <TextBlock Text="GitHub" FontWeight="SemiBold" Margin="10,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource DarkButton}" Background="{DynamicResource GlassOverlayBrush}" BorderThickness="1" Padding="15,8">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Fill="{DynamicResource MutedTextBrush}" Stretch="Uniform" Width="14" Height="14" Data="M7.8,2H16.2C19.4,2 22,4.6 22,7.8V16.2C22,19.4 19.4,22 16.2,22H7.8C4.6,22 2,19.4 2,16.2V7.8C2,4.6 4.6,2 7.8,2ZM7.6,4C5.6,4 4,5.6 4,7.6V16.4C4,18.4 5.6,20 7.6,20H16.4C18.4,20 20,18.4 20,16.4V7.6C20,5.6 18.4,4 16.4,4H7.6ZM12,6.875C14.83,6.875 17.125,9.17 17.125,12C17.125,14.83 14.83,17.125 12,17.125C9.17,17.125 6.875,14.83 6.875,12C6.875,9.17 9.17,6.875 12,6.875ZM12,8.875C10.27,8.875 8.875,10.27 8.875,12C8.875,13.73 10.27,15.125 12,15.125C13.73,15.125 15.125,13.73 15.125,12C15.125,10.27 13.73,8.875 12,8.875ZM16.5,6.25C17.19,6.25 17.75,6.81 17.75,7.5C17.75,8.19 17.19,8.75 16.5,8.75C15.81,8.75 15.25,8.19 15.25,7.5C15.25,6.81 15.81,6.25 16.5,6.25Z"/>
                                            <TextBlock Text="Instagram" FontWeight="SemiBold" Margin="10,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="SavePresetOverlay" Visibility="Collapsed" Opacity="0">
            <Border Background="#B2000000" MouseLeftButtonDown="CloseSavePreset_Click"/>
            <Border Style="{StaticResource GlassPanel}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="320" Padding="25" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="SavePresetScale" ScaleX="0.95" ScaleY="0.95"/>
                </Border.RenderTransform>
                <StackPanel>
                    <TextBlock Text="Save Custom Preset" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,15"/>
                    <TextBox x:Name="PresetNameInput" Style="{StaticResource GlassTextBox}" Height="32" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource DarkButton}" Padding="15,6" Margin="0,0,10,0" Click="CloseSavePreset_Click"/>
                        <Button Content="Save" Style="{StaticResource DarkButton}" Background="{DynamicResource AccentBrush}" Foreground="White" Padding="15,6" Click="ConfirmSavePreset_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="ToastNotification" Background="{DynamicResource AccentBrush}" CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40" Padding="20,12" Visibility="Collapsed" Opacity="0" IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>
            <TextBlock x:Name="ToastText" Text="Preset Saved Successfully!" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
        </Border>

        <Popup x:Name="ColorPickerPopup" PlacementTarget="{Binding ElementName=CustomColorBtn}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
            <Border Background="{DynamicResource WindowBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5,0,0" Width="200">
                <StackPanel>
                    <TextBlock Text="Custom Color" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <TextBlock Text="HEX Code (e.g. #FF5C61)" Foreground="{DynamicResource MutedTextBrush}" FontSize="10" Margin="0,0,0,2"/>
                    <TextBox x:Name="HexInputBox" Style="{StaticResource GlassTextBox}" Margin="0,0,0,10" TextChanged="HexInputBox_TextChanged"/>

                    <TextBlock Text="Red" Foreground="{DynamicResource MutedTextBrush}" FontSize="10"/>
                    <Slider x:Name="RedSlider" Minimum="0" Maximum="255" Value="92" Style="{StaticResource VolumeSlider}" Margin="0,5,0,10" ValueChanged="ColorSlider_ValueChanged"/>

                    <TextBlock Text="Green" Foreground="{DynamicResource MutedTextBrush}" FontSize="10"/>
                    <Slider x:Name="GreenSlider" Minimum="0" Maximum="255" Value="97" Style="{StaticResource VolumeSlider}" Margin="0,5,0,10" ValueChanged="ColorSlider_ValueChanged"/>

                    <TextBlock Text="Blue" Foreground="{DynamicResource MutedTextBrush}" FontSize="10"/>
                    <Slider x:Name="BlueSlider" Minimum="0" Maximum="255" Value="255" Style="{StaticResource VolumeSlider}" Margin="0,5,0,15" ValueChanged="ColorSlider_ValueChanged"/>

                    <Border x:Name="ColorPreviewBox" Height="30" CornerRadius="4" Background="{DynamicResource AccentBrush}"/>
                    <Button Content="Apply Color" Style="{StaticResource DarkButton}" Height="28" Margin="0,10,0,0" Click="ApplyCustomColor_Click"/>
                </StackPanel>
            </Border>
        </Popup>

        <Image x:Name="ThemeTransitionOverlay" Visibility="Collapsed" IsHitTestVisible="False" Stretch="Fill"/>

        <!-- Invisible Resize Grip -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="20" Height="20" Background="Transparent" Cursor="SizeNWSE" MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown" Panel.ZIndex="999"/>
    </Grid>
</Window>