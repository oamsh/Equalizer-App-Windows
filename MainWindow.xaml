                                            <TextBlock Grid.Column="7" Text="5 kHz" Foreground="{DynamicResource MutedTextBrush}" FontSize="9" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="8" Text="10 kHz" Foreground="{DynamicResource MutedTextBrush}" FontSize="9" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="9" Text="20 kHz" Foreground="{DynamicResource MutedTextBrush}" FontSize="9" HorizontalAlignment="Center"/>
