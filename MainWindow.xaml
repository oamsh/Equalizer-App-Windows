                    <Border x:Name="SettingsContentPanel" Grid.Column="1" Style="{StaticResource GlassPanel}" Margin="0,0,10,10" Padding="25" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="20" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="0,0,10,0">

                                    <Border Style="{StaticResource GlassOverlay}" Padding="20" Margin="0,0,0,15">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="🎧" Foreground="{DynamicResource AccentBrush}" FontSize="16" Margin="0,0,10,0"/>
                                                <TextBlock Text="Audio Engine" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="16"/>
                                            </StackPanel>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                                    <TextBlock Text="Equalizer APO Config Path" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="The path to the config.txt file used by the audio processing engine." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBox Width="200" Text="C:\Program Files\EqualizerAPO\config\config.txt" Style="{StaticResource GlassTextBox}" Margin="0,0,10,0" IsReadOnly="True" Foreground="{DynamicResource MutedTextBrush}"/>
                                                    <Button Content="Browse" Style="{StaticResource DarkButton}" Width="70" Height="28"/>
                                                </StackPanel>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Clipping Protection (0.0 dB Limit)" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Prevents the preamp from exceeding 0.0 dB to protect your speakers." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource GlassOverlay}" Padding="20" Margin="0,0,0,15">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="👁️" Foreground="{DynamicResource AccentBrush}" FontSize="16" Margin="0,0,10,0"/>
                                                <TextBlock Text="Visualizer &amp; Graphics" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="16"/>
                                            </StackPanel>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Visualizer Frame Rate" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Lower the frame rate to save CPU/GPU resources on laptops." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <ComboBox x:Name="VisualizerFpsSelector" Grid.Column="1" Width="150" Height="30" SelectedIndex="1" Style="{StaticResource DarkComboBox}" VerticalAlignment="Center" SelectionChanged="VisualizerFpsSelector_SelectionChanged">
                                                    <ComboBoxItem Content="30 FPS (Eco)"/>
                                                    <ComboBoxItem Content="60 FPS (Default)"/>
                                                    <ComboBoxItem Content="120 FPS (Ultra)"/>
                                                </ComboBox>
                                            </Grid>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Spectrum Falloff Speed" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Controls how fast the spectrum bars drop after a bass hit." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <Slider x:Name="SpectrumFalloffSlider" Grid.Column="1" Width="150" Value="40" Maximum="100" Style="{StaticResource VolumeSlider}" VerticalAlignment="Center" ValueChanged="SpectrumFalloffSlider_ValueChanged"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Disable Visualizers (Eco Mode)" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Completely pauses all background visualizer rendering." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <ToggleButton x:Name="EcoModeToggle" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="False" VerticalAlignment="Center" Click="EcoModeToggle_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource GlassOverlay}" Padding="20" Margin="0,0,0,10">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="⚙️" Foreground="{DynamicResource AccentBrush}" FontSize="16" Margin="0,0,10,0"/>
                                                <TextBlock Text="Application" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="16"/>
                                            </StackPanel>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Start with Windows" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Automatically load your Equalizer profile when the PC turns on." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <ToggleButton x:Name="StartWithWindowsToggle" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" VerticalAlignment="Center" Click="StartWithWindowsToggle_Click"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Minimize to System Tray" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Hide the app to the taskbar instead of closing it entirely." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <ToggleButton x:Name="MinimizeToTrayToggle" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" VerticalAlignment="Center"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Always on Top" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Keep the application floating above other windows." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <ToggleButton x:Name="AlwaysOnTopToggle" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="False" VerticalAlignment="Center" Click="AlwaysOnTopToggle_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border x:Name="FxContentPanel" Grid.Column="1" Style="{StaticResource GlassPanel}" Margin="0,0,10,10" Padding="25" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Studio Effects" FontWeight="SemiBold" FontSize="20" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="0,0,10,0">

                                    <Border Style="{StaticResource GlassOverlay}" Padding="20" Margin="0,0,0,15">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,20">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="🎛️" Foreground="{DynamicResource AccentBrush}" FontSize="16" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Dynamic Compressor" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="16"/>
                                                </StackPanel>
                                                <ToggleButton x:Name="CompressorToggle" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="False"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="50"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Threshold" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center"/>
                                                <Slider x:Name="CompThresholdSlider" Grid.Column="1" Minimum="-60" Maximum="0" Value="-20" Style="{StaticResource VolumeSlider}" VerticalAlignment="Center" Margin="10,0"/>
                                                <TextBlock Text="{Binding Value, ElementName=CompThresholdSlider, StringFormat={}{0:0} dB}" Grid.Column="2" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="50"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Ratio" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center"/>
                                                <Slider x:Name="CompRatioSlider" Grid.Column="1" Minimum="1" Maximum="20" Value="4" Style="{StaticResource VolumeSlider}" VerticalAlignment="Center" Margin="10,0"/>
                                                <TextBlock Text="{Binding Value, ElementName=CompRatioSlider, StringFormat={}{0:0.0} : 1}" Grid.Column="2" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource GlassOverlay}" Padding="20" Margin="0,0,0,15">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,20">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="↔️" Foreground="{DynamicResource AccentBrush}" FontSize="16" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Stereo Widener" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="16"/>
                                                </StackPanel>
                                                <ToggleButton x:Name="StereoToggle" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="False"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="50"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Width" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center"/>
                                                <Slider x:Name="StereoWidthSlider" Grid.Column="1" Minimum="0" Maximum="200" Value="130" Style="{StaticResource VolumeSlider}" VerticalAlignment="Center" Margin="10,0"/>
                                                <TextBlock Text="{Binding Value, ElementName=StereoWidthSlider, StringFormat={}{0:0}%}" Grid.Column="2" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource GlassOverlay}" Padding="20">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,20">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="✂️" Foreground="{DynamicResource AccentBrush}" FontSize="16" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Precision Filters" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="16"/>
                                                </StackPanel>
                                                <ToggleButton x:Name="FiltersToggle" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="False"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="High-Pass" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center"/>
                                                <Slider x:Name="HighPassSlider" Grid.Column="1" Minimum="20" Maximum="1000" Value="80" Style="{StaticResource VolumeSlider}" VerticalAlignment="Center" Margin="10,0"/>
                                                <TextBlock Text="{Binding Value, ElementName=HighPassSlider, StringFormat={}{0:0} Hz}" Grid.Column="2" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Low-Pass" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center"/>
                                                <Slider x:Name="LowPassSlider" Grid.Column="1" Minimum="1000" Maximum="20000" Value="18000" Style="{StaticResource VolumeSlider}" VerticalAlignment="Center" Margin="10,0"/>
                                                <TextBlock Text="{Binding Value, ElementName=LowPassSlider, StringFormat={}{0:0} Hz}" Grid.Column="2" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                </Grid>

                <Border Grid.Row="2" Style="{StaticResource GlassPanel}" Margin="10,0,10,10" Padding="20,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="35"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="35"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CurrentTimeText" Text="0:00" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>

                            <Grid Grid.Column="1" VerticalAlignment="Center" Margin="8,0">

                                <Path x:Name="WaveformPathUnplayed" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1.5" Stretch="Fill" Height="14" VerticalAlignment="Center" IsHitTestVisible="False"/>

                                <Path x:Name="WaveformPathPlayed" Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5" Stretch="Fill" Height="14" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <Path.Clip>
                                        <RectangleGeometry x:Name="WaveformPlayedMask" Rect="0,0,0,20"/>
                                    </Path.Clip>
                                </Path>

                                <Slider x:Name="SeekSlider" Minimum="0" Maximum="100" Opacity="0"
                                        Thumb.DragStarted="SeekSlider_DragStarted" 
                                        Thumb.DragCompleted="SeekSlider_DragCompleted" 
                                        ValueChanged="SeekSlider_ValueChanged"
                                        PreviewMouseLeftButtonUp="SeekSlider_PreviewMouseLeftButtonUp"/>
                            </Grid>

                            <TextBlock x:Name="TotalTimeText" Text="0:00" Grid.Column="2" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Border Width="48" Height="48" Style="{StaticResource GlassOverlay}">
                                    <Grid>
                                        <Path x:Name="TrackIcon" Fill="{DynamicResource AccentBrush}" Stretch="Uniform" Width="22" Height="22" Data="M9,3 L19,1 L19,12 A3.5,3.5 0 1,1 15.5,15.5 L15.5,7 L9,8 L9,14 A3.5,3.5 0 1,1 5.5,17.5 L5.5,3 Z"/>
                                        <Border CornerRadius="5">
                                            <Border.Background>
                                                <ImageBrush x:Name="TrackImageBrush" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                    </Grid>
                                </Border>
                                <StackPanel VerticalAlignment="Center" Margin="15,0,0,0">
                                    <TextBlock x:Name="TrackTitle" Text="Unknown Track" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="14"/>
                                    <TextBlock x:Name="TrackArtist" Text="Unknown Artist" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Style="{StaticResource DarkButton}" BorderThickness="0" Margin="0,0,15,0" Width="35" Height="35">
                                    <Path Stroke="{DynamicResource MutedTextBrush}" StrokeThickness="1.5" Stretch="Uniform" Width="14" Height="14" Data="M2,10 L5,7 M9,3 L13,3 L13,7 M13,3 L9,7 M2,2 L13,13 M9,13 L13,13 L13,9"/>
                                </Button>
                                <Button Click="Previous_Click" Style="{StaticResource DarkButton}" BorderThickness="0" Margin="0,0,15,0" Width="35" Height="35">
                                    <Path Fill="{DynamicResource MutedTextBrush}" Stretch="Uniform" Width="12" Height="12" Data="M10,2 L10,14 L3,8 Z M2,2 L3,2 L3,14 L2,14 Z"/>
                                </Button>

                                <Border x:Name="PlayPauseBorder" MouseLeftButtonDown="PlayPause_Click" Cursor="Hand" Width="44" Height="44" Background="{DynamicResource AccentBrush}" CornerRadius="22" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="15" ShadowDepth="0"/>
                                    </Border.Effect>
                                    <Path x:Name="PlayPauseIcon" Fill="White" Stretch="Uniform" Width="14" Height="14" Margin="3,0,0,0" Data="M2,2 L14,8 L2,14 Z"/>
                                </Border>

                                <Button Click="Next_Click" Style="{StaticResource DarkButton}" BorderThickness="0" Margin="15,0,0,0" Width="35" Height="35">
                                    <Path Fill="{DynamicResource MutedTextBrush}" Stretch="Uniform" Width="12" Height="12" Data="M2,2 L2,14 L9,8 Z M10,2 L11,2 L11,14 L10,14 Z"/>
                                </Button>
                                <Button Style="{StaticResource DarkButton}" BorderThickness="0" Margin="15,0,0,0" Width="35" Height="35">
                                    <Path Stroke="{DynamicResource MutedTextBrush}" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform" Width="14" Height="14" Data="M4,4 L12,4 A4,4 0 0,1 12,12 L4,12 A4,4 0 0,1 4,4 M10,2 L12,4 L10,6 M6,14 L4,12 L6,10"/>
                                </Button>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Path Fill="{DynamicResource MutedTextBrush}" Stretch="Uniform" Width="14" Height="14" Margin="0,0,12,0" Data="M2,5 L5,5 L9,2 L9,14 L5,11 L2,11 Z M11,4 A5,5 0 0,1 11,12 M13,2 A8,8 0 0,1 13,14"/>
                                <Slider x:Name="VolumeSliderControl" Style="{StaticResource VolumeSlider}" Width="110" Maximum="100" Value="80" VerticalAlignment="Center" ValueChanged="VolumeSliderControl_ValueChanged"/>
                                <TextBlock Text="{Binding Value, ElementName=VolumeSliderControl, StringFormat={}{0:0}%}" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="15,0,0,0" Width="30" TextAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid x:Name="AboutOverlay" Visibility="Collapsed" Opacity="0">
            <Border Background="#B2000000" MouseLeftButtonDown="CloseAbout_Click"/>

            <Border Style="{StaticResource GlassPanel}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="420" Padding="35" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="AboutScale" ScaleX="0.95" ScaleY="0.95"/>
                </Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Width="24" Height="24" BorderThickness="0" Background="Transparent" Click="CloseAbout_Click" Margin="0,-15,-15,0" Cursor="Hand">
                        <Path Stroke="{DynamicResource MutedTextBrush}" StrokeThickness="2" Stretch="Uniform" Width="10" Height="10" Data="M0,0 L10,10 M10,0 L0,10"/>
                    </Button>

                    <Border Grid.Row="0" Width="100" Height="100" CornerRadius="50" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{DynamicResource AccentColorLight}" Offset="0.0"/>
                                <GradientStop Color="{DynamicResource AccentColor}" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                        </Border.Effect>
                        <Grid>
                            <Ellipse Margin="3">
                                <Ellipse.Fill>
                                    <ImageBrush x:Name="ProfileImageBrush" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="1" Text="Om" Foreground="{DynamicResource TextBrush}" FontWeight="Bold" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Grid.Row="2" Text="Software Developer" Foreground="{DynamicResource AccentBrushLight}" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <TextBlock Grid.Row="3" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" FontSize="13" LineHeight="20" Margin="0,0,0,30">
