<Window x:Class="EqualizerPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Equalizer Pro" Height="768" Width="1100"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Foreground="{DynamicResource TextBrush}"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Color x:Key="AccentColor">#5C61FF</Color>
        <Color x:Key="AccentColorLight">#A07BFF</Color>
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}"/>
        <SolidColorBrush x:Key="AccentBrushLight" Color="{DynamicResource AccentColorLight}"/>

        <SolidColorBrush x:Key="WindowBgBrush" Color="#990B0E14"/>
        <SolidColorBrush x:Key="PanelBgBrush" Color="#730B0E14"/>
        <SolidColorBrush x:Key="TextBrush" Color="White"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#A9B1D6"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#26FFFFFF"/>
        <SolidColorBrush x:Key="GlassOverlayBrush" Color="#1AFFFFFF"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#33FFFFFF"/>

        <LinearGradientBrush x:Key="SpectrumGradientBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource AccentColorLight}" Offset="0.0"/>
            <GradientStop Color="{DynamicResource AccentColor}" Offset="0.5"/>
            <GradientStop Color="#1AFFFFFF" Offset="1.0"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="FreqFillGradientBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource AccentColorLight}" Offset="0.0"/>
            <GradientStop Color="{DynamicResource AccentColor}" Offset="0.6"/>
            <GradientStop Color="#00111520" Offset="1.0"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="VuMeterGradientBrush" StartPoint="0,1" EndPoint="0,0">
            <GradientStop Color="#10B981" Offset="0.0"/>
            <GradientStop Color="#10B981" Offset="0.6"/>
            <GradientStop Color="#F59E0B" Offset="0.8"/>
            <GradientStop Color="#EF4444" Offset="0.95"/>
        </LinearGradientBrush>

        <Style x:Key="GlassTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource GlassOverlayBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border" CornerRadius="12" Background="{DynamicResource BorderBrush}">
                            <Ellipse x:Name="Knob" Width="18" Height="18" Fill="{DynamicResource MutedTextBrush}" HorizontalAlignment="Left" Margin="3,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Knob" Property="Fill" Value="White"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Knob" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="22" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Knob" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FatToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border" CornerRadius="20" Background="{DynamicResource GlassOverlayBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <Border x:Name="Glow" CornerRadius="20" Background="{DynamicResource AccentBrush}" Opacity="0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="15" ShadowDepth="0"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock x:Name="Txt" Text="OFF" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" FontWeight="Bold" FontSize="14"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Txt" Property="Text" Value="FAT"/>
                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="25" ShadowDepth="10" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassOverlay" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource GlassOverlayBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource GlassOverlayBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" VerticalAlignment="Center" Margin="10,0"/>
                                    <Path Grid.Column="1" Stroke="{DynamicResource MutedTextBrush}" StrokeThickness="1.5" Data="M0,0 L4,4 L8,0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2,0,0"/>
                                    <ToggleButton Grid.ColumnSpan="2" Opacity="0" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="{DynamicResource WindowBgBrush}" BorderBrush="{DynamicResource HoverBrush}" BorderThickness="1" Margin="0,2,0,0" CornerRadius="6" MinWidth="{TemplateBinding ActualWidth}">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeonSlider" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="IsDirectionReversed" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Width="20">
                            <Border Width="2" Background="{DynamicResource BorderBrush}" HorizontalAlignment="Center" CornerRadius="1" Margin="0,8"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Width="2" Background="{DynamicResource AccentBrush}" HorizontalAlignment="Center" Margin="0,8"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="White" Stroke="{DynamicResource AccentBrush}" StrokeThickness="3">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="12" ShadowDepth="0"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VolumeSlider" TargetType="Slider">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="20">
                            <Border Height="4" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center" CornerRadius="2" Margin="8,0"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="{DynamicResource AccentBrush}" VerticalAlignment="Center" CornerRadius="2" Margin="8,0,0,0"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="White" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="10" ShadowDepth="0"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SpectrumBar" TargetType="Border">
            <Setter Property="Margin" Value="1.5,0"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="CornerRadius" Value="1.5,1.5,0,0"/>
            <Setter Property="Background" Value="{DynamicResource SpectrumGradientBrush}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border x:Name="WindowBorder" Background="{DynamicResource WindowBgBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="120"/>
                </Grid.RowDefinitions>

                <Grid x:Name="TopBarGrid" Grid.Row="0" Background="Transparent" Margin="15,0">
                    <TextBlock x:Name="AppTitleText" Text="Equalizer Pro" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextBrush}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                        <TextBlock x:Name="CompactEqLabel" Text="EQ:" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Visibility="{Binding Visibility, ElementName=CompactEqToggle}"/>
                        <ToggleButton x:Name="CompactEqToggle" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" Visibility="Collapsed" Click="CompactEqToggle_Click" Margin="0,0,20,0" ToolTip="Enable/Disable Equalizer"/>

                        <TextBlock Text="Theme:" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
                        <ComboBox x:Name="ThemeSelector" Width="120" Height="26" SelectedIndex="0" Style="{StaticResource DarkComboBox}" Margin="0,0,10,0" SelectionChanged="ThemeSelector_ThemeChanged">
                            <ComboBoxItem Content="Blue (Default)"/>
                            <ComboBoxItem Content="Red"/>
                            <ComboBoxItem Content="Green"/>
                            <ComboBoxItem Content="Orange"/>
                            <ComboBoxItem Content="Purple"/>
                            <ComboBoxItem Content="Cyan"/>
                        </ComboBox>

                        <Button x:Name="CustomColorBtn" Content="🎨" Width="26" Height="26" Style="{StaticResource DarkButton}" Margin="0,0,10,0" Click="CustomColorBtn_Click" ToolTip="Custom Color" FontSize="12"/>

                        <Button x:Name="ModeSwitchBtn" Content="☀" Width="35" Height="26" Style="{StaticResource DarkButton}" Margin="0,0,10,0" Click="ModeSwitchBtn_Click" ToolTip="Toggle Light/Dark Mode" FontSize="14"/>

                        <Button x:Name="CompactModeBtn" Content="🗗" Width="35" Height="26" Style="{StaticResource DarkButton}" Margin="0,0,20,0" Click="CompactModeBtn_Click" ToolTip="Toggle Compact Mode" FontSize="14"/>

                        <Button Content="—" Width="35" Style="{StaticResource DarkButton}" BorderThickness="0" Click="Minimize_Click"/>
                        <Button Content="□" Width="35" Style="{StaticResource DarkButton}" BorderThickness="0" Click="Maximize_Click"/>
                        <Button Content="✕" Width="35" Style="{StaticResource DarkButton}" BorderThickness="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="SidebarBorder" Grid.Column="0" Width="220" Style="{StaticResource GlassPanel}" Margin="10,0,10,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="10,20,10,0">

                                <Border x:Name="NavEqActive" Style="{StaticResource GlassOverlay}" Padding="15,12" Margin="0,0,0,5" Visibility="Visible">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5" Stretch="Uniform" Width="14" Height="14" Data="M2,4 L2,14 M8,2 L8,14 M14,6 L14,14 M0,4 L4,4 M6,2 L10,2 M12,6 L16,6"/>
                                        <TextBlock Text="Equalizer" Foreground="{DynamicResource TextBrush}" Margin="15,0,0,0" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Button x:Name="NavEqBtn" Style="{StaticResource DarkButton}" BorderThickness="0" Padding="15,12" HorizontalContentAlignment="Left" Margin="0,0,0,5" Click="EqualizerBtn_Click" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Stroke="{DynamicResource MutedTextBrush}" StrokeThickness="1.5" Stretch="Uniform" Width="14" Height="14" Data="M2,4 L2,14 M8,2 L8,14 M14,6 L14,14 M0,4 L4,4 M6,2 L10,2 M12,6 L16,6"/>
                                        <TextBlock Text="Equalizer" Margin="15,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Border x:Name="NavFxActive" Style="{StaticResource GlassOverlay}" Padding="15,12" Margin="0,0,0,5" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="✨" Foreground="{DynamicResource AccentBrush}" FontSize="16" FontFamily="Segoe UI Symbol" Margin="0,-2,0,0"/>
                                        <TextBlock Text="Studio FX" Foreground="{DynamicResource TextBrush}" Margin="15,0,0,0" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Button x:Name="NavFxBtn" Style="{StaticResource DarkButton}" BorderThickness="0" Padding="15,12" HorizontalContentAlignment="Left" Margin="0,0,0,5" Click="FxBtn_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✨" Foreground="{DynamicResource MutedTextBrush}" FontSize="16" FontFamily="Segoe UI Symbol" Margin="0,-2,0,0"/>
                                        <TextBlock Text="Studio FX" Margin="15,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource DarkButton}" BorderThickness="0" Padding="15,12" HorizontalContentAlignment="Left" Margin="0,0,0,5">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Stroke="{DynamicResource MutedTextBrush}" StrokeThickness="1.5" Stretch="Uniform" Width="14" Height="14" Data="M8,1 L10,5 L15,5 L11,8 L13,13 L8,10 L3,13 L5,8 L1,5 L6,5 Z"/>
                                        <TextBlock Text="Presets" Margin="15,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource DarkButton}" BorderThickness="0" Padding="15,12" HorizontalContentAlignment="Left" Margin="0,0,0,5">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Stroke="{DynamicResource MutedTextBrush}" StrokeThickness="1.5" Stretch="Uniform" Width="14" Height="14" Data="M8,1 A7,7 0 1,1 7.9,1 M6,4 L11,8 L6,12 Z"/>
                                        <TextBlock Text="Playback" Margin="15,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Border x:Name="NavRecordActive" Style="{StaticResource GlassOverlay}" Padding="15,12" Margin="0,0,0,5" Visibility="Collapsed" MouseLeftButtonDown="RecordBtn_Click" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse x:Name="RecordBlinkDot" Width="12" Height="12" Fill="#FF4444" Margin="1,0,0,0"/>
                                        <TextBlock x:Name="RecordTimeText" Text="00:00" Foreground="{DynamicResource TextBrush}" Margin="16,0,0,0" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Button x:Name="NavRecordBtn" Style="{StaticResource DarkButton}" BorderThickness="0" Padding="15,12" HorizontalContentAlignment="Left" Margin="0,0,0,5" Click="RecordBtn_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="12" Height="12" Stroke="{DynamicResource MutedTextBrush}" StrokeThickness="1.5" Margin="1,0,0,0"/>
                                        <TextBlock Text="Record" Margin="16,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Border x:Name="NavSettingsActive" Style="{StaticResource GlassOverlay}" Padding="15,12" Margin="0,0,0,5" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="⚙" Foreground="{DynamicResource AccentBrush}" FontSize="16" FontFamily="Segoe UI Symbol" Margin="0,-2,0,0"/>
                                        <TextBlock Text="Settings" Foreground="{DynamicResource TextBrush}" Margin="15,0,0,0" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Button x:Name="NavSettingsBtn" Style="{StaticResource DarkButton}" BorderThickness="0" Padding="15,12" HorizontalContentAlignment="Left" Margin="0,0,0,5" Click="SettingsBtn_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚙" Foreground="{DynamicResource MutedTextBrush}" FontSize="16" FontFamily="Segoe UI Symbol" Margin="0,-2,0,0"/>
                                        <TextBlock Text="Settings" Margin="15,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource DarkButton}" BorderThickness="0" Padding="15,12" HorizontalContentAlignment="Left" Margin="0,0,0,5" Click="AboutBtn_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="ⓘ" Foreground="{DynamicResource MutedTextBrush}" FontSize="16" FontFamily="Segoe UI Symbol" Margin="0,-2,0,0"/>
                                        <TextBlock Text="About" Margin="15,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="15,0,15,20">
                                <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,20"/>
                                <TextBlock Text="Analog Fatness" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" Margin="0,0,0,15" ToolTip="Simulates analog saturation and warmth"/>

                                <ToggleButton x:Name="FatModeToggle" Style="{StaticResource FatToggleStyle}" IsChecked="False" Click="FatModeToggle_Click" Margin="0,10,0,10"/>

                                <TextBlock Text="Saturation / Warmth" Foreground="{DynamicResource MutedTextBrush}" FontSize="10" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid x:Name="EqContentPanel" Grid.Column="1" Margin="0,0,10,10" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="60"/>
                            <RowDefinition Height="2*"/>
                            <RowDefinition Height="1.2*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Equalizer" FontWeight="SemiBold" FontSize="18" Margin="0,0,15,0" Foreground="{DynamicResource TextBrush}"/>
                                <ToggleButton x:Name="GlobalEqToggle" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" Click="GlobalEqToggle_Click"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Select Preset" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                <ComboBox x:Name="PresetSelector" Width="160" Height="32" SelectedIndex="0" Style="{StaticResource DarkComboBox}" SelectionChanged="PresetSelector_SelectionChanged">
                                    <ComboBoxItem Content="Custom"/>
                                    <ComboBoxItem Content="Acoustic"/>
                                    <ComboBoxItem Content="Bass Boost"/>
                                    <ComboBoxItem Content="Electronic"/>
                                    <ComboBoxItem Content="Vocal"/>
                                    <ComboBoxItem Content="Rock"/>
