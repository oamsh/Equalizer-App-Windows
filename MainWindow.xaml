                                            <Path x:Name="SpectrumLinePath" Stretch="Fill" Stroke="{DynamicResource AccentBrushLight}" StrokeThickness="2" StrokeLineJoin="Round" Margin="0,6,0,6" Visibility="Collapsed" VerticalAlignment="Bottom" Height="80" IsHitTestVisible="False" />

