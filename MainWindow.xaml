        <Popup x:Name="ColorPickerPopup" PlacementTarget="{Binding ElementName=CustomColorBtn}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
            <Border Background="{DynamicResource WindowBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5,0,0" Width="200">
                <StackPanel>
                    <TextBlock Text="Custom Color" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <TextBlock Text="HEX Code (e.g. #FF5C61)" Foreground="{DynamicResource MutedTextBrush}" FontSize="10" Margin="0,0,0,2"/>
                    <TextBox x:Name="HexInputBox" Style="{StaticResource GlassTextBox}" Margin="0,0,0,10" TextChanged="HexInputBox_TextChanged"/>

                    <TextBlock Text="Red" Foreground="{DynamicResource MutedTextBrush}" FontSize="10"/>
                    <Slider x:Name="RedSlider" Minimum="0" Maximum="255" Value="92" Style="{StaticResource VolumeSlider}" Margin="0,5,0,10" ValueChanged="ColorSlider_ValueChanged"/>

                    <TextBlock Text="Green" Foreground="{DynamicResource MutedTextBrush}" FontSize="10"/>
                    <Slider x:Name="GreenSlider" Minimum="0" Maximum="255" Value="97" Style="{StaticResource VolumeSlider}" Margin="0,5,0,10" ValueChanged="ColorSlider_ValueChanged"/>

                    <TextBlock Text="Blue" Foreground="{DynamicResource MutedTextBrush}" FontSize="10"/>
                    <Slider x:Name="BlueSlider" Minimum="0" Maximum="255" Value="255" Style="{StaticResource VolumeSlider}" Margin="0,5,0,15" ValueChanged="ColorSlider_ValueChanged"/>

                    <Border x:Name="ColorPreviewBox" Height="30" CornerRadius="4" Background="{DynamicResource AccentBrush}"/>
                    <Button Content="Apply Color" Style="{StaticResource DarkButton}" Height="28" Margin="0,10,0,0" Click="ApplyCustomColor_Click"/>
                </StackPanel>
            </Border>
        </Popup>

        <Image x:Name="ThemeTransitionOverlay" Visibility="Collapsed" IsHitTestVisible="False" Stretch="Fill"/>
    </Grid>
</Window>